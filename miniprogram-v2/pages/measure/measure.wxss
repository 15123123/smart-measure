/* pages/measure/measure.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --primary-light: #A5B4FC;
  --success: #10B981;
  --locked: #64748B;
  --danger: #EF4444;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* Loading */
.loading-view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loader {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 30rpx 32rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.page-header.locked {
  background: linear-gradient(135deg, var(--locked), #94A3B8);
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0));
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== Content ===== */
.page-content {
  padding: 24rpx;
  margin-top: -10rpx;
}

/* Info Card (closed state) */
.info-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
}

.state-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.state-text {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 10rpx;
}

.state-time {
  font-size: 26rpx;
  color: var(--text-tertiary);
  margin-bottom: 30rpx;
}

/* Form Card */
.form-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-title {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.title-icon {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.card-title text:last-child {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-body {
  padding: 20rpx 24rpx;
}

/* Form Item */
.form-item {
  margin-bottom: 20rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 84rpx;
  padding: 0 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(102,126,234,0.15);
}

.form-input.disabled {
  color: var(--text-tertiary);
  background: #F1F5F9;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-col {
  flex: 1;
}

/* Gender */
.gender-box {
  display: flex;
  gap: 12rpx;
}

.gender-btn {
  flex: 1;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  transition: all 0.2s;
}

.gender-btn.active {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  font-weight: 600;
}

/* Measure Grid */
.measure-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.measure-item {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
}

.measure-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

.measure-input {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 10rpx;
  overflow: hidden;
}

.measure-input input {
  flex: 1;
  height: 72rpx;
  padding: 0 16rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: var(--primary);
  background: transparent;
  border: none;
}

.measure-input input::placeholder {
  color: var(--text-tertiary);
  font-weight: 400;
}

.input-unit {
  padding: 0 14rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: var(--text-tertiary);
  background: #F1F5F9;
}

/* Remark */
.remark-input {
  width: 100%;
  min-height: 140rpx;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  resize: none;
}

/* Back Link */
.back-link-card {
  text-align: center;
  padding: 24rpx;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

.space { height: 160rpx; }

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  padding: 20rpx 24rpx 36rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.btn-group {
  display: flex;
  gap: 14rpx;
}

.btn-primary, .btn-secondary {
  flex: 1;
  height: 92rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(102,126,234,0.35);
}

.btn-secondary {
  background: #F1F5F9;
  color: var(--text-secondary);
}

.btn-primary text, .btn-secondary text {
  margin-right: 8rpx;
}

/* Back Button (closed state) */
.btn-back {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 20rpx;
}


.form-value {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  text-align: right;
}