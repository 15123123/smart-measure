<!--pages/measure/measure.wxml-->
<view class="container">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-view">
    <view class="loader"></view>
  </view>
  
  <block wx:else>
    <!-- 顶部 -->
    <view class="page-header {{projectClosed ? 'locked' : ''}}">
      <view class="header-bg"></view>
      <view class="header-content">
        <view class="header-icon">{{projectClosed ? '🔒' : '📐'}}</view>
        <view class="header-title">{{projectClosed ? '项目已截止' : '量体录入'}}</view>
        <view class="header-subtitle">{{projectClosed ? '无法修改数据' : '请填写测量数据'}}</view>
      </view>
    </view>
    
    <!-- 内容 -->
    <view class="page-content">
      <!-- 截止状态 -->
      <block wx:if="{{projectClosed}}">
        <view class="info-card">
          <view class="state-icon">⏰</view>
          <view class="state-text">项目已截止</view>
          <view class="state-time">{{deadline}}</view>
          <view class="btn-back" bindtap="goBack">‹ 返回</view>
        </view>
      </block>
      
      <!-- 正常表单 -->
      <block wx:else>
        <!-- 基本信息 -->
        <view class="form-card">
          <view class="card-title">
            <text class="title-icon">01</text>
            <text>基本信息</text>
          </view>
          <view class="form-body">
            <view class="form-item">
              <text class="form-label">供给证号</text>
              <text class="form-value">{{supply_no || '-'}}</text>
            </view>
            <view class="form-item">
              <text class="form-label">检索号</text>
              <text class="form-value">{{search_no || '-'}}</text>
            </view>
            <view class="form-row">
              <view class="form-col" style="width:100%">
                <view class="form-item">
                  <text class="form-label">性别</text>
                  <view class="gender-box">
                    <view class="gender-btn {{gender === '男' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="男">男</view>
                    <view class="gender-btn {{gender === '女' ? 'active' : ''}}" bindtap="onGenderSelect" data-gender="女">女</view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 测量数据 -->
        <view class="form-card">
          <view class="card-title">
            <text class="title-icon">02</text>
            <text>测量数据</text>
          </view>
          <view class="form-body">
            <view class="measure-grid">
              <view class="measure-item">
                <text class="measure-label">身高</text>
                <view class="measure-input">
                  <input type="digit" value="{{height}}" data-field="height" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">体重</text>
                <view class="measure-input">
                  <input type="digit" value="{{weight}}" data-field="weight" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">kg</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">头围</text>
                <view class="measure-input">
                  <input type="digit" value="{{head_tail}}" data-field="head_tail" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">颈围</text>
                <view class="measure-input">
                  <input type="digit" value="{{neck_circumference}}" data-field="neck_circumference" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">肩宽</text>
                <view class="measure-input">
                  <input type="digit" value="{{shoulder_width}}" data-field="shoulder_width" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">胸围</text>
                <view class="measure-input">
                  <input type="digit" value="{{chest_circumference}}" data-field="chest_circumference" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">腰围</text>
                <view class="measure-input">
                  <input type="digit" value="{{waist_circumference}}" data-field="waist_circumference" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">袖长</text>
                <view class="measure-input">
                  <input type="digit" value="{{sleeve_length}}" data-field="sleeve_length" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">臀围</text>
                <view class="measure-input">
                  <input type="digit" value="{{hip_circumference}}" data-field="hip_circumference" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">裤长</text>
                <view class="measure-input">
                  <input type="digit" value="{{pants_length}}" data-field="pants_length" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">cm</text>
                </view>
              </view>
              <view class="measure-item">
                <text class="measure-label">鞋码</text>
                <view class="measure-input">
                  <input type="digit" value="{{shoe_size}}" data-field="shoe_size" bindinput="onInput" placeholder="0" />
                  <text class="input-unit">码</text>
                </view>
              </view>
            </view>
          </view>
        </view>
        
        <!-- 备注 -->
        <view class="form-card">
          <view class="card-title">
            <text class="title-icon">03</text>
            <text>备注</text>
          </view>
          <view class="form-body">
            <textarea class="remark-input" value="{{remark}}" data-field="remark" bindinput="onInput" placeholder="特殊情况备注..." />
          </view>
        </view>
        
        <!-- 返回 -->
        <view class="back-link-card" bindtap="goBack">‹ 返回上一页</view>
        
        <view class="space"></view>
      </block>
    </view>
    
    <!-- 底部按钮 -->
    <view class="action-bar" wx:if="{{!projectClosed}}">
      <view class="btn-group">
        <view class="btn-primary" bindtap="onSiteConfirm">
          <text>✓</text> 现场确认
        </view>
        <view class="btn-secondary" bindtap="onOffSiteConfirm">
          <text>○</text> 非现场
        </view>
      </view>
    </view>
  </block>
</view>
