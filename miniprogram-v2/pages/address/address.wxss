/* pages/address/address.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --success: #10B981;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* Loading */
.loading-view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 50vh;
}

.loader {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 30rpx 32rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0));
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== Content ===== */
.page-content {
  padding: 24rpx;
  margin-top: -20rpx;
  padding-bottom: 140rpx;
}

/* Info Card */
.info-card, .form-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-title {
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-list {
  padding: 8rpx 24rpx 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.info-item.no-line {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary);
}

/* Form */
.form-body {
  padding: 20rpx 24rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-input:focus {
  background: #fff;
  box-shadow: 0 0 0 3rpx rgba(102,126,234,0.15);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx;
  background: #F8FAFC;
  border-radius: 14rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
  resize: none;
}

/* Back */
.back-link {
  text-align: center;
  padding: 24rpx;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
}

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  padding: 20rpx 24rpx 36rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
  z-index: 100;
}

.btn-save {
  height: 92rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102,126,234,0.35);
}
