<!--pages/address/address.wxml-->
<view class="container">
  <!-- Header -->
  <view class="page-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <view class="header-icon">📦</view>
      <view class="header-title">收件信息</view>
      <view class="header-subtitle">填写收货地址以便配送</view>
    </view>
  </view>
  
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-view">
    <view class="loader"></view>
  </view>
  
  <block wx:else>
    <!-- Content -->
    <view class="page-content">
      <!-- 量体信息 -->
      <view class="info-card">
        <view class="card-title">
          <text class="title-text">量体信息</text>
        </view>
        <view class="info-list">
          <view class="info-item">
            <text class="info-label">检索号</text>
            <text class="info-value">{{name}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">上装尺码</text>
            <text class="info-value">{{top_size}}</text>
          </view>
          <view class="info-item no-line">
            <text class="info-label">下装尺码</text>
            <text class="info-value">{{bottom_size}}</text>
          </view>
        </view>
      </view>
      
      <!-- 收件信息 -->
      <view class="form-card">
        <view class="card-title">
          <text class="title-text">收件信息</text>
        </view>
        <view class="form-body">
          <view class="form-item">
            <text class="form-label">收件人</text>
            <input class="form-input" value="{{receiver_name}}" data-field="receiver_name" bindinput="onInput" placeholder="请输入收件人姓名" />
          </view>
          <view class="form-item">
            <text class="form-label">联系电话</text>
            <input class="form-input" value="{{receiver_phone}}" data-field="receiver_phone" bindinput="onInput" type="number" maxlength="11" placeholder="请输入联系电话" />
          </view>
          <view class="form-item">
            <text class="form-label">收件地址</text>
            <textarea class="form-textarea" value="{{receiver_address}}" data-field="receiver_address" bindinput="onInput" placeholder="请输入详细收件地址" />
          </view>
        </view>
      </view>
      
      <!-- 返回 -->
      <view class="back-link" bindtap="goBack">‹ 返回</view>
    </view>
    
    <!-- 底部按钮 -->
    <view class="action-bar">
      <view class="btn-save" bindtap="onSave">保存并继续</view>
    </view>
  </block>
</view>
