/* pages/index/index.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --primary-light: #A5B4FC;
  --success: #10B981;
  --success-light: #34D399;
  --danger: #EF4444;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container {
  min-height: 100vh;
}

/* Loading */
.loading-view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loader {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ===== 搜索结果页 ===== */
.result-wrapper {
  min-height: 100vh;
  padding: 40rpx 32rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.success-circle {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, var(--success), var(--success-light));
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 12rpx 32rpx rgba(16, 185, 129, 0.35);
}

.success-circle text {
  color: #fff;
  font-size: 56rpx;
  font-weight: bold;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* Result Card */
.result-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 32rpx;
}

.info-list {
  padding: 8rpx 0;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.info-item.no-line {
  border-bottom: none;
}

.info-left {
  display: flex;
  align-items: center;
}

.info-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
}

.info-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.info-right {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-right.project {
  color: var(--primary);
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Action Buttons */
.action-buttons {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 20rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-primary .btn-arrow {
  font-size: 36rpx;
  margin-left: 10rpx;
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border);
  border-radius: 20rpx;
  color: var(--text-secondary);
  font-size: 30rpx;
  font-weight: 500;
}

/* ===== 搜索页面 ===== */
.search-page {
  min-height: 100vh;
  padding: 60rpx 32rpx 40rpx;
}

/* Top Section */
.top-section {
  text-align: center;
  margin-bottom: 48rpx;
}

.app-logo {
  width: 140rpx;
  height: 140rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(102, 126, 234, 0.4);
}

.app-logo text {
  color: #fff;
  font-size: 56rpx;
  font-weight: 700;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.app-subtitle {
  font-size: 24rpx;
  color: var(--text-tertiary);
  letter-spacing: 2rpx;
}

/* Search Card */
.search-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  margin-bottom: 24rpx;
}

.search-header {
  margin-bottom: 28rpx;
}

.search-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.search-desc {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

/* Input */
.input-group {
  margin-bottom: 24rpx;
}

.input-wrap {
  display: flex;
  align-items: center;
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 96rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: var(--text-primary);
  height: 100%;
}

.search-input::placeholder {
  color: var(--text-tertiary);
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--border);
  border-radius: 50%;
  color: var(--text-secondary);
  font-size: 22rpx;
}

/* Button */
.btn-search {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 18rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.35);
}

/* Error */
.error-tip {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FEF2F2;
  border-radius: 12rpx;
  text-align: center;
}

.error-tip text {
  color: var(--danger);
  font-size: 26rpx;
}

/* Tips Card */
.tips-card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tips-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.tips-item {
  display: flex;
  align-items: flex-start;
}

.tips-dot {
  width: 10rpx;
  height: 10rpx;
  background: var(--primary-light);
  border-radius: 50%;
  margin-top: 14rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.tips-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.6;
}
