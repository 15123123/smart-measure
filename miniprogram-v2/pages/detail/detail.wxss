/* pages/detail/detail.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --primary-light: #A5B4FC;
  --success: #10B981;
  --locked: #64748B;
  --danger: #EF4444;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* Loading */
.loading-view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loader {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 30rpx 32rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.1;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="white"/></svg>');
  background-size: 200rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
}

.header-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
}

/* ===== Content ===== */
.content {
  padding: 32rpx;
  padding-bottom: 180rpx;
}

/* ===== Info Card ===== */
.info-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border);
}

.card-icon {
  font-size: 36rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.info-item.no-border {
  border-bottom: none;
  padding-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

/* ===== Data Card ===== */
.data-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.measure-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.measure-item {
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.measure-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
  display: block;
}

.measure-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.measure-value .unit {
  font-size: 20rpx;
  color: var(--text-tertiary);
  font-weight: normal;
}

/* ===== Clothing Table ===== */
.clothing-table {
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  overflow: hidden;
}

.table-header {
  display: flex;
  background: var(--bg-page);
  padding: 20rpx 16rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-secondary);
}

.table-body {
  background: white;
}

.table-row {
  display: flex;
  padding: 20rpx 16rpx;
  border-top: 1rpx solid var(--border);
  font-size: 26rpx;
}

/* 优化列宽：服装品名占40%，其他各占20% */
.th-name, .td-name { width: 40%; text-align: left; }
.th-recommend, .td-recommend { width: 20%; text-align: center; }
.th-size, .td-size { width: 20%; text-align: center; }
.th-remark, .td-remark { width: 20%; text-align: center; }

/* 列内文字截断处理 */
.td-name {
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding-right: 10rpx;
}

.td-recommend { color: var(--success); }
.td-size { color: var(--primary); }
.td-remark { 
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 表头样式优化 */
.th-name { padding-right: 10rpx; }

/* ===== History Card ===== */
.history-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.title-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.toggle-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

.history-list {
  margin-top: 20rpx;
}

.history-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--border);
}

.history-item:last-child {
  border-bottom: none;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 50%;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.history-main {
  flex: 1;
}

.history-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.history-action {
  font-size: 26rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.history-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.history-user {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-top: 8rpx;
}

.user-icon {
  font-size: 24rpx;
}

.user-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.history-arrow {
  font-size: 32rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

.empty-history {
  text-align: center;
  padding: 40rpx;
}

.empty-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-tertiary);
}

/* ===== Buttons ===== */
.btn-home {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  padding: 24rpx 0;
  border-radius: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.btn-home text {
  margin-right: 8rpx;
}

.save-btn {
  position: fixed;
  bottom: 40rpx;
  left: 32rpx;
  right: 32rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: white;
  padding: 24rpx 0;
  border-radius: 60rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

/* ===== Modal ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 90%;
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-tertiary);
}

.modal-body {
  padding: 32rpx;
}

.compare-info {
  margin-bottom: 24rpx;
  padding: 16rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
}

.compare-time {
  font-size: 26rpx;
  color: var(--text-secondary);
  display: block;
  margin-bottom: 8rpx;
}

.compare-user {
  font-size: 24rpx;
  color: var(--text-tertiary);
}

.compare-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.compare-item {
  padding: 16rpx;
  background: var(--bg-page);
  border-radius: 12rpx;
}

.compare-field {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.compare-values {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.compare-old, .compare-new {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.compare-old .tag, .compare-new .tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.compare-old .tag {
  background: #FEE2E2;
  color: var(--danger);
}

.compare-new .tag {
  background: #D1FAE5;
  color: var(--success);
}

.compare-old .val, .compare-new .val {
  font-size: 26rpx;
  color: var(--text-primary);
}

.arrow {
  color: var(--text-tertiary);
  font-size: 28rpx;
}


.remark-row {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid var(--border);
  display: flex;
  gap: 16rpx;
}

.remark-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.remark-value {
  font-size: 26rpx;
  color: var(--text-primary);
}