/* pages/detail/detail.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --primary-light: #A5B4FC;
  --success: #10B981;
  --success-light: #D1FAE5;
  --danger: #EF4444;
  --danger-light: #FEE2E2;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* Loading */
.loading-view {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loader {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 30rpx 32rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0));
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== Content ===== */
.page-content {
  padding: 24rpx;
  margin-top: -10rpx;
}

/* Form Card */
.form-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-title {
  display: flex;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.title-icon {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 6rpx 12rpx;
  border-radius: 8rpx;
  margin-right: 12rpx;
}

.title-count {
  font-size: 22rpx;
  color: var(--text-tertiary);
  margin-left: auto;
  background: #F1F5F9;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.toggle-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: auto;
  transition: transform 0.3s;
}

.toggle-arrow.up {
  transform: rotate(90deg);
}

.card-title .title-count {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.form-body {
  padding: 20rpx 24rpx;
}

/* Form Item */
.form-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-secondary);
}

.form-value {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  text-align: right;
}

/* Measure Grid - 1x3 */
.measure-grid-3 {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.measure-item {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx 12rpx;
  text-align: center;
}

.measure-label {
  display: block;
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 12rpx;
}

.measure-display {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.measure-value {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--primary);
}

.measure-unit {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-left: 4rpx;
}

/* Remark Row */
.remark-row {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #FEF3C7;
  border-radius: 12rpx;
}

.remark-label {
  display: block;
  font-size: 24rpx;
  color: #92400E;
  margin-bottom: 8rpx;
}

.remark-value {
  font-size: 28rpx;
  color: #78350F;
}

/* Clothing List */
.clothing-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.clothing-item {
  background: #F8FAFC;
  border-radius: 16rpx;
  padding: 20rpx;
}

.clothing-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 12rpx;
}

.clothing-sizes {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.size-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: #fff;
  color: var(--text-secondary);
}

.size-tag.recommend {
  background: linear-gradient(135deg, #8B5CF6, #A78BFA);
  color: #fff;
  font-weight: 600;
}

.size-tag.green {
  background: var(--success);
  color: #fff;
  font-weight: 600;
}

.clothing-remark {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx dashed var(--border);
}

/* History */
.history-body {
  padding: 16rpx 24rpx 24rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
}

.history-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F1F5F9;
}

.history-item:last-child {
  border-bottom: none;
}

.history-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--primary);
  border-radius: 50%;
  margin-right: 16rpx;
  margin-top: 6rpx;
  flex-shrink: 0;
}

.history-content {
  flex: 1;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.history-action {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.history-time {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.history-user {
  font-size: 24rpx;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.source-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.source-tag.miniprogram {
  background: #e8f5e9;
  color: #2e7d32;
}

.source-tag.admin {
  background: #fff3e0;
  color: #ef6c00;
}

.history-arrow {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-left: 16rpx;
  margin-top: 4rpx;
}

.empty-history {
  text-align: center;
  padding: 40rpx 0;
  color: var(--text-tertiary);
  font-size: 28rpx;
}

/* Back Link */
.back-link-card {
  text-align: center;
  padding: 24rpx;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

.space { height: 40rpx; }

/* ===== Modal ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.modal-content {
  background: #fff;
  border-radius: 24rpx;
  width: 100%;
  max-height: 80vh;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-tertiary);
  padding: 10rpx;
}

.modal-body {
  padding: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
}

/* Compare */
.compare-info {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid var(--border);
}

.compare-time {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.compare-user {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.compare-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.compare-item {
  background: #F8FAFC;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
}

.compare-field {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.compare-values {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.compare-old, .compare-new {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tag.red {
  background: var(--danger-light);
  color: var(--danger);
}

.tag.green {
  background: var(--success-light);
  color: var(--success);
}

.tag {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 4rpx;
  font-weight: 600;
}

.compare-old .val, .compare-new .val {
  font-size: 28rpx;
  color: var(--text-primary);
}

.arrow {
  color: var(--text-tertiary);
  font-size: 28rpx;
}
