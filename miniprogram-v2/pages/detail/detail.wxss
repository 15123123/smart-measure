/* pages/detail/detail.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --success: #10B981;
  --warning: #F59E0B;
  --danger: #EF4444;
  --bg-page: #F8FAFC;
  --bg-card: white;
  --text-primary: #1F2937;
  --text-secondary: #6B7280;
  --text-tertiary: #9CA3AF;
  --border: #E5E7EB;
}

.container {
  padding: 24rpx;
  background: var(--bg-page);
  min-height: 100vh;
}

.header {
  margin-bottom: 24rpx;
}

.back-btn {
  display: inline-flex;
  align-items: center;
  font-size: 28rpx;
  color: var(--primary);
  margin-bottom: 16rpx;
}

.back-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.page-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx;
}

.loading-text {
  font-size: 28rpx;
  color: var(--text-tertiary);
  margin-top: 20rpx;
}

/* ===== Basic Info Card ===== */
.basic-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.person-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: white;
  margin-right: 24rpx;
}

.person-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.person-meta {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-top: 8rpx;
}

.person-meta text {
  margin-right: 16rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.info-value.highlight {
  color: var(--primary);
}

.info-value.warning {
  color: var(--warning);
}

.info-value.success {
  color: var(--success);
}

/* ===== Measurement Section ===== */
.section-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.measure-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.measure-item {
  background: var(--bg-page);
  border-radius: 16rpx;
  padding: 20rpx;
  text-align: center;
}

.measure-label {
  font-size: 24rpx;
  color: var(--text-tertiary);
  margin-bottom: 8rpx;
  display: block;
}

.measure-value {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text-primary);
  display: block;
}

.measure-value .unit {
  font-size: 20rpx;
  color: var(--text-tertiary);
  font-weight: normal;
}

/* ===== Clothing Table ===== */
.clothing-table {
  border: 1rpx solid var(--border);
  border-radius: 16rpx;
  overflow: hidden;
  margin-top: 20rpx;
}

.table-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #F3F4F6, #E5E7EB);
  padding: 24rpx 16rpx;
  font-size: 24rpx;
  font-weight: bold;
  color: #6B7280;
}

.table-body {
  background: white;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 20rpx 16rpx;
  border-top: 1rpx solid #F3F4F6;
  font-size: 26rpx;
  line-height: 1.5;
}

.th-name, .td-name { width: 38%; text-align: left; padding-right: 8rpx; }
.th-recommend, .td-recommend { width: 22%; text-align: center; }
.th-size, .td-size { width: 22%; text-align: center; }
.th-remark, .td-remark { width: 18%; text-align: center; }

.td-name {
  color: var(--text-primary);
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-recommend { 
  color: #8B5CF6; 
  font-weight: bold;
  font-size: 28rpx;
}

.td-size { 
  color: var(--primary); 
  font-weight: 600;
  font-size: 28rpx;
}

.td-remark { 
  color: #9CA3AF;
  font-size: 22rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.th-name { padding-right: 8rpx; }

/* ===== History Card ===== */
.history-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}
