/* pages/clothing/clothing.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --success: #10B981;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 30rpx 32rpx 50rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0));
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.header-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== Content ===== */
.page-content {
  padding: 24rpx;
  margin-top: -10rpx;
  padding-bottom: 140rpx;
}

/* Card */
.form-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.card-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  border-bottom: 2rpx solid var(--border);
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.add-btn {
  font-size: 26rpx;
  color: var(--primary);
  font-weight: 500;
}

/* Table */
.clothing-table {
  padding: 0;
}

.table-header {
  display: flex;
  background: linear-gradient(90deg, #1E293B, #334155);
  padding: 16rpx 12rpx;
}

.table-header text {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
  text-align: center;
}

.th-name { width: 25%; }
.th-recommend { width: 15%; }
.th-size { width: 25%; }
.th-remark { width: 35%; }

.table-body {
  background: #F8FAFC;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid var(--border);
}

.table-row:last-child {
  border-bottom: none;
}

.td-name, .td-recommend, .td-size, .td-remark {
  text-align: center;
  font-size: 22rpx;
}

.td-name { width: 25%; }
.td-recommend { width: 15%; color: var(--success); font-weight: 600; }
.td-size { width: 25%; }
.td-remark { width: 35%; }

.picker-text {
  color: var(--text-primary);
}

.td-size input, .td-remark input {
  width: 100%;
  text-align: center;
  font-size: 22rpx;
  background: #fff;
  padding: 8rpx;
  border-radius: 8rpx;
  border: 1rpx solid var(--border);
}

.empty-tip {
  padding: 40rpx;
  text-align: center;
  color: var(--text-tertiary);
  font-size: 26rpx;
}

/* Back */
.back-link {
  text-align: center;
  padding: 24rpx;
  color: var(--primary);
  font-size: 28rpx;
  font-weight: 500;
}

/* ===== Action Bar ===== */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  padding: 20rpx 24rpx 36rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.06);
}

.btn-save {
  height: 92rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(102,126,234,0.35);
}
