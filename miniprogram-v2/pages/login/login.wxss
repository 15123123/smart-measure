/* pages/login/login.wxss */

page {
  --primary: #667EEA;
  --primary-dark: #764BA2;
  --danger: #EF4444;
  --bg-page: #F0F4FF;
  --bg-card: #FFFFFF;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-tertiary: #94A3B8;
  --border: #E2E8F0;
  
  background: var(--bg-page);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'PingFang SC', sans-serif;
}

.container { min-height: 100vh; }

/* ===== Header ===== */
.page-header {
  position: relative;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  padding: 80rpx 32rpx 100rpx;
  border-radius: 0 0 40rpx 40rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.15), rgba(255,255,255,0));
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
  text-align: center;
}

.logo-area {
  margin-bottom: 24rpx;
}

.logo-icon {
  width: 140rpx;
  height: 140rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto;
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.header-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* ===== Login Card ===== */
.login-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  margin: -40rpx 24rpx 24rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  text-align: center;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: var(--text-tertiary);
  text-align: center;
  margin-bottom: 32rpx;
}

/* Error */
.error-box {
  background: #FEF2F2;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  text-align: center;
}

.error-box text {
  color: var(--danger);
  font-size: 24rpx;
}

/* Button */
.btn-login {
  height: 96rpx;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(102,126,234,0.35);
  margin-bottom: 24rpx;
}

/* Skip */
.skip-link {
  text-align: center;
  color: var(--primary);
  font-size: 26rpx;
  padding: 16rpx;
}

/* ===== Features ===== */
.features-card {
  display: flex;
  margin: 0 24rpx;
  gap: 16rpx;
}

.feature-item {
  flex: 1;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.feature-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.feature-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 6rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: var(--text-tertiary);
}
